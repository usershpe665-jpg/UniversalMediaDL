# ─── LunarMediaDL — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# On Railway: set these in your project's Variables panel.

# ── Download Directories ──────────────────────────────────────────────────────
# Where finished files are saved (must be a persistent volume on Railway)
DOWNLOAD_DIR=/downloads

# Optional: separate directory for audio downloads (defaults to DOWNLOAD_DIR)
# AUDIO_DOWNLOAD_DIR=/downloads/audio

# Temporary working directory during downloads
TEMP_DIR=/tmp/lunarmetube

# State / queue persistence directory
STATE_DIR=/tmp/lunarmetube

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8081
HOST=0.0.0.0

# URL prefix if running behind a reverse proxy at a sub-path (e.g. /dl/)
# URL_PREFIX=/

# ── Cookies (for age-restricted or member-only content) ──────────────────────
# Paste your Netscape-format cookie file content here — no base64 encoding needed.
# Example (multi-line values work in Railway):
#
# COOKIES=# Netscape HTTP Cookie File
# .youtube.com	TRUE	/	TRUE	0	SID	xxxx...
# .youtube.com	TRUE	/	TRUE	0	HSID	xxxx...
#
# Leave empty to disable cookie support:
COOKIES=

# ── yt-dlp Advanced Options (JSON) ───────────────────────────────────────────
# Optional extra yt-dlp options as a JSON object.
# Example: YTDL_OPTIONS={"nocheckcertificate": true, "geo_bypass": true}
YTDL_OPTIONS={}

# ── Downloads Behaviour ───────────────────────────────────────────────────────
# Maximum simultaneous downloads (default: 3)
MAX_CONCURRENT_DOWNLOADS=3

# Output filename template (yt-dlp format)
OUTPUT_TEMPLATE=%(title)s.%(ext)s

# ── Access Control ────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated). Leave empty to disable CORS headers.
# CORS_ALLOWED_ORIGINS=https://mysite.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOGLEVEL=INFO
